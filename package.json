{
  "name": "hello",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000 --base=/egsm/",
    "build": "vite build --base=/egsm/",
    "preview": "vite preview --host --base=/egsm/",
    "build:github": "vite build --base=/egsm/",
    "deploy": "npm run build:github && npx gh-pages -d dist -b gh-pages -r https://github.com/skyDevet/egsm.git",
    "capacitor:add": "npx cap add android",
    "capacitor:sync": "npx cap sync",
    "capacitor:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "gh-pages": "^6.3.0",
    "vite": "^5.0.0"
  }
}